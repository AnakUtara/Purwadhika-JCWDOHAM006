<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Shrinker - Your Image is Ready!</title>
	</head>
	<body
		style="background:#f7f7f7; margin:0; padding:0; font-family: 'Segoe UI', Arial, sans-serif;"
	>
		<table
			width="100%"
			cellpadding="0"
			cellspacing="0"
			style="background:#f7f7f7; min-height:100vh;"
		>
			<tr>
				<td align="center">
					<table
						width="100%"
						cellpadding="0"
						cellspacing="0"
						style="max-width:420px; background:#fff; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.07); margin:40px 0; padding:32px;"
					>
						<tr>
							<td align="center" style="padding-bottom:24px;">
								<div
									style="font-size:32px; color:#222; font-weight:700; letter-spacing:1px;"
								>Shrinker</div>
							</td>
						</tr>
						<tr>
							<td align="center" style="padding-bottom:16px;">
								<div style="font-size:20px; color:#222; font-weight:600;">Your
									image is ready!</div>
							</td>
						</tr>
						<tr>
							<td align="center" style="padding-bottom:24px;">
								<div style="font-size:15px; color:#444;">
									Thank you for using
									<span style="color:#222; font-weight:500;">Shrinker</span>.<br
									/>
									Your image has been successfully compressed.<br />
									Please find your shrunk image attached below.<br />
									<br />
									<span style="font-size:13px; color:#888;">Enjoy your optimized
										image!</span>
								</div>
							</td>
						</tr>
						<tr>
							<td align="center" style="padding-top:12px;">
								<a
									href="{{siteUrl}}"
									style="display:inline-block; background:#222; color:#fff; text-decoration:none; padding:10px 28px; border-radius:6px; font-size:15px; font-weight:500; letter-spacing:0.5px;"
								>Visit Shrinker</a>
							</td>
						</tr>
						<tr>
							<td
								align="center"
								style="padding-top:32px; font-size:12px; color:#bbb;"
							>
								&copy;
								{{year}}
								Shrinker. All rights reserved.
							</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>