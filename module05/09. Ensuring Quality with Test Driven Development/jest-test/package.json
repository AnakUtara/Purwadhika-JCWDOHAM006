{
	"name": "jest-api",
	"version": "1.0.0",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "npx prisma generate && npx tsc",
		"start": "node dist/src/server.js",
		"test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --detectOpenHandles --forceExit",
		"test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --detectOpenHandles --forceExit --testPathPatterns='./tests/unit'",
		"test:int": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --detectOpenHandles --forceExit --testPathPatterns='./tests/integration'",
		"mig:dev": "npx prisma migrate dev",
		"gen:dev": "npx prisma generate"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"type": "module",
	"dependencies": {
		"@prisma/adapter-neon": "^7.4.2",
		"@prisma/client": "^7.4.2",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.75.2",
		"cloudinary": "^2.9.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.0",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.1.0",
		"node-cron": "^4.2.1",
		"ts-node": "^10.9.2",
		"winston": "^3.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.0.0",
		"@types/supertest": "^7.2.0",
		"jest": "^30.3.0",
		"jest-mock-extended": "^4.0.1",
		"nock": "^14.0.13",
		"prisma": "^7.4.2",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.9",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
