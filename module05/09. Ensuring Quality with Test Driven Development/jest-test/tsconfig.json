{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
		"rootDir": "./" /* This keeps the folder structure identical in dist */,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"types": ["jest", "node"],
		"ignoreDeprecations": "6.0"
	},
	"include": ["**/*"],
	"exclude": ["node_modules", "dist"]
}
